# ===== RemnaShop-Pro Docker 生产环境示例 =====
# 复制为 .env 后再启动：cp .env.example .env

# 时区（建议按服务器实际时区设置）
TZ=UTC

# 安装引导阶段仅要求以下两项（会在 bootstrap.sh 中交互写入 .env）
ADMIN_ID=123456789
BOT_TOKEN=123456:ABCDEF

# 以下项目均为可选：安装不会因它们缺失而阻塞
# 可在机器人/应用内后续补充配置
PANEL_URL=https://panel.example.com
PANEL_TOKEN=your_panel_api_token
SUB_DOMAIN=https://sub.example.com
GROUP_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PANEL_VERIFY_TLS=true
